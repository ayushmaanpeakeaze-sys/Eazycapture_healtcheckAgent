# EazyCapture AI Agent — runtime configuration template.
# Copy to .env and fill in real values. Never commit the populated .env.

# --- Groq LLM ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- Redis (used by /api/v1/enrich-audit + Celery) ---
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@127.0.0.1:6379/2

# --- Health-check AI feature gate ---
# Flip to true once GROQ_API_KEY and REDIS_URL are filled in.
HEALTHCHECK_AI_ENABLED=false

# Per-row record TTL in seconds. Default = 30 days.
HEALTHCHECK_AI_TTL_SECONDS=2592000

# --- Postgres (POC: /api/v1/health/* endpoints) ---
# docker-compose binds container 5432 -> host 5434 (5433 is used by Django).
POSTGRES_USER=hcpoc
POSTGRES_PASSWORD=hcpoc
POSTGRES_DB=healthcheck_poc
POSTGRES_PORT=5434
DATABASE_URL=postgresql+asyncpg://hcpoc:hcpoc@127.0.0.1:5434/healthcheck_poc

# --- AI FastAPI URLs (POC calls back into this same process) ---
HEALTHCHECK_AI_BASE_URL=http://127.0.0.1:8001
HEALTHCHECK_AI_BATCH_URL=http://127.0.0.1:8001/api/v1/health-check/batch
HEALTHCHECK_AI_ENRICH_URL=http://127.0.0.1:8001/api/v1/enrich-audit
HEALTHCHECK_AI_SUGGEST_FIX_URL=http://127.0.0.1:8001/api/v1/suggest-fix
HEALTHCHECK_AI_TIMEOUT_MS=600000
HEALTHCHECK_AI_ENRICH_TIMEOUT_MS=5000
HEALTHCHECK_BATCH_HASH_TTL_SECONDS=3600

# --- Nango (placeholders — ask sir for prod values) ---
# Leaving these empty keeps the service in "stub" mode: audits read
# seeded data and resolves log instead of calling Xero. Set
# NANGO_SECRET_KEY to flip to live Nango mode without code changes.
NANGO_BASE_URL=https://api.nango.dev
NANGO_SECRET_KEY=
NANGO_WEBHOOK_SECRET=
NANGO_USER_ID=poc-demo-user
NANGO_XERO_INTEGRATION_ID=xero
# Hard cap on pagination — a stuck connection can't pull forever.
MAX_NANGO_PAGES=10

# --- Deployment environment ---
# development | staging | production. When set to "production" the app
# REFUSES to boot with insecure config (AUTH_DISABLED=true, a weak/empty
# JWT_SECRET, or no DATABASE_URL). Keep "development" locally.
APP_ENV=development

# --- Auth (this service issues its OWN JWTs — independent product) ---
# AUTH_DISABLED=true OR an empty JWT_SECRET → POC mode (endpoints open, no
# auth). MUST be false + a strong secret in production.
AUTH_DISABLED=false
# Generate a strong one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
# Access-token lifetime in hours (default 12).
JWT_TTL_HOURS=12

# Login brute-force protection: lock an account after N failed attempts
# within the window (seconds). A successful login resets the counter.
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_SECONDS=300

# --- Email / notifications ---
# SMTP_HOST empty → invites are logged (console) instead of emailed.
# For Gmail use an App Password (not your login password).
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
APP_NAME=EazyCapture
# Frontend origin + route the invite link points at.
APP_BASE_URL=http://localhost:3000
ACCEPT_INVITE_PATH=/accept-invite
# Shared secret the email provider signs delivery/bounce webhooks with.
# Empty → webhook accepted with a logged warning (set it in production).
EMAIL_WEBHOOK_SECRET=

# --- CORS (frontend origins allowed to call the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
